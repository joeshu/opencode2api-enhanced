# Copy this file to .env before running docker compose.

API_KEY=change-me
OPENCODE_SERVER_PASSWORD=change-me-too

# Select profile:
# stable        = stable mobile-friendly mode (tools off)
# tools-stable  = mobile-friendly tool mode (tools on, lower concurrency, longer timeouts)
OPENCODE_PROFILE=stable

# Common prompt defaults
OPENCODE_PROXY_PROMPT_MODE=plugin-inject
OPENCODE_PROXY_OMIT_SYSTEM_PROMPT=true

# Periodically clean proxy-owned conversation/session storage.
OPENCODE_PROXY_AUTO_CLEANUP_CONVERSATIONS=true
OPENCODE_PROXY_CLEANUP_INTERVAL_MS=43200000
OPENCODE_PROXY_CLEANUP_MAX_AGE_MS=86400000

# Optional overrides
# Any explicit override below wins over OPENCODE_PROFILE defaults.
# OPENCODE_DISABLE_TOOLS=true
# OPENCODE_PROXY_PORT=10000
# OPENCODE_SERVER_PORT=10001
# OPENCODE_USE_ISOLATED_HOME=false
# OPENCODE_PROXY_REQUEST_TIMEOUT_MS=180000
# OPENCODE_PROXY_SERVER_REQUEST_TIMEOUT_MS=210000
# OPENCODE_PROXY_SERVER_HEADERS_TIMEOUT_MS=65000
# OPENCODE_PROXY_SERVER_KEEPALIVE_TIMEOUT_MS=5000
# OPENCODE_PROXY_SERVER_SOCKET_TIMEOUT_MS=240000
# OPENCODE_PROXY_SHUTDOWN_GRACE_MS=10000
# OPENCODE_PROXY_MAX_IMAGE_BYTES=10485760
# OPENCODE_PROXY_ALLOW_PRIVATE_IMAGE_HOSTS=false
# OPENCODE_PROXY_MAX_CONCURRENT_REQUESTS=8
# OPENCODE_ZEN_API_KEY=
